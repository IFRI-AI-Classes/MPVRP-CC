<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soumission — MPVRP-CC</title>
    <link rel="stylesheet" href="static/css/style.css">
    <style>
  
        .auth-container {
            max-width: 460px;
            margin: 40px auto;
            padding: 30px;
            border: 1px solid #ddd;
            border-radius: 6px;
            background: #fff;
        }

        .auth-container h2 {
            border-bottom: none;
            margin-bottom: 5px;
            padding-bottom: 0;
        }

        .auth-subtitle {
            color: #888;
            font-size: 15px;
            margin-bottom: 25px;
        }

        .tabs {
            display: flex;
            border-bottom: 2px solid #eee;
            margin-bottom: 25px;
        }

        .tabs button {
            flex: 1;
            padding: 10px;
            border: none;
            background: none;
            cursor: pointer;
            font-family: inherit;
            font-size: 16px;
            color: #888;
            transition: color 0.2s;
        }

        .tabs button.active {
            color: #3C27F5;
            border-bottom: 2px solid #3C27F5;
            font-weight: bold;
            margin-bottom: -2px;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            font-size: 15px;
        }

        .form-group input {
            width: 100%;
            padding: 9px 11px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
            font-family: inherit;
            font-size: 15px;
            transition: border-color 0.2s;
        }

        .form-group input:focus {
            outline: none;
            border-color: #3C27F5;
        }

        .btn-auth {
            width: 100%;
            padding: 10px;
            background-color: #3C27F5;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
            font-family: inherit;
            margin-top: 5px;
            transition: background-color 0.2s, opacity 0.2s;
        }

        .btn-auth:hover:not(:disabled) { background-color: #2d1fd4; }
        .btn-auth:disabled              { opacity: 0.65; cursor: not-allowed; }

        /* ── Espace utilisateur ─────────────────────────────── */
        .user-space { display: none; }

        .upload-card {
            border: 2px dashed #3C27F5;
            padding: 30px;
            text-align: center;
            margin: 25px 0;
            border-radius: 8px;
            background: #fafafe;
        }

        .upload-card h3  { margin-bottom: 8px; color: #2c3e50; }
        .upload-card p   { color: #666; font-size: 15px; margin-bottom: 15px; }

        .upload-card input[type="file"] {
            display: block;
            margin: 0 auto 15px;
            font-family: inherit;
            font-size: 15px;
        }

        .btn-upload {
            background: #3C27F5;
            color: #fff;
            border: none;
            border-radius: 4px;
            padding: 9px 22px;
            font-size: 15px;
            font-family: inherit;
            cursor: pointer;
            transition: background-color 0.2s, opacity 0.2s;
        }

        .btn-upload:hover:not(:disabled) { background-color: #2d1fd4; }
        .btn-upload:disabled              { opacity: 0.65; cursor: not-allowed; }

        /* ── Bannière message ───────────────────────────────── */
        .msg-banner {
            border-radius: 4px;
            padding: 10px 14px;
            margin-top: 15px;
            font-size: 15px;
            line-height: 1.5;
            transition: opacity 0.4s;
        }

        /* ── Bouton Détails dans l'historique ───────────────── */
        .btn-details {
            background: none;
            border: 1px solid #3C27F5;
            color: #3C27F5;
            cursor: pointer;
            padding: 3px 10px;
            border-radius: 4px;
            font-size: 13px;
            font-family: inherit;
            transition: background 0.15s, color 0.15s;
        }

        .btn-details:hover:not(:disabled) {
            background: #3C27F5;
            color: #fff;
        }

        .btn-details:disabled { opacity: 0.5; cursor: not-allowed; }

        /* ── Logout ─────────────────────────────────────────── */
        .btn-logout {
            margin-top: 20px;
            background: none;
            border: 1px solid #e74c3c;
            color: #e74c3c;
            cursor: pointer;
            padding: 6px 14px;
            border-radius: 4px;
            font-family: inherit;
            font-size: 14px;
            transition: background 0.15s, color 0.15s;
        }

        .btn-logout:hover {
            background: #e74c3c;
            color: #fff;
        }

        /* ── Badges statut ──────────────────────────────────── */
        .badge {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 13px;
            font-weight: bold;
            letter-spacing: 0.02em;
        }
        .badge-ok  { background: #e8f8ee; color: #1e8449; border: 1px solid #a9dfbf; }
        .badge-err { background: #fdf2f2; color: #c0392b; border: 1px solid #f5b7b1; }

        /* ── Section résultat ───────────────────────────────── */
        #result-section { margin-top: 30px; }

        #result-section details summary {
            cursor: pointer;
            color: #3C27F5;
            font-weight: bold;
            padding: 8px 0;
            user-select: none;
        }
    </style>
</head>
<body>

<header>
    <h1>
        MPVRP-CC
        <span>Espace Soumission</span>
    </h1>
    <nav>
        <div class="menu-toggle" id="mobile-menu">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </div>
        <ul class="nav-links" id="nav-links">
            <li><a href="../index.html">Accueil</a></li>
            <li><a href="leaderboard.html">Leaderboard</a></li>
            <li><a href="submission.html" class="active">Soumission</a></li>
            <li id="nav-team-name" style="display:none; color:#3C27F5; font-weight:bold; font-size:15px; padding: 0 5px;"></li>
            <li id="nav-logout-li" style="display:none;">
                <a href="#" onclick="logout(); return false;" style="color:#e74c3c;">Déconnexion</a>
            </li>
        </ul>
    </nav>
</header>

<section>


    <div id="auth-section" class="auth-container">
        <h2>Espace équipe</h2>
        <p class="auth-subtitle">Connectez-vous pour soumettre vos solutions et suivre votre score.</p>

        <div class="tabs">
            <button id="tab-login"    class="active" onclick="switchTab('login')">Connexion</button>
            <button id="tab-register"                onclick="switchTab('register')">S'inscrire</button>
        </div>

        <form id="auth-form" onsubmit="handleAuth(event)">
            <div id="group-team" class="form-group" style="display:none;">
                <label for="team_name">Nom de l'équipe</label>
                <input type="text" id="team_name" autocomplete="organization">
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" required autocomplete="email">
            </div>
            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" required autocomplete="current-password">
            </div>
            <button type="submit" id="submit-btn" class="btn-auth">Se connecter</button>
        </form>
    </div>

    <!-- ── ESPACE UTILISATEUR (visible si connecté) ────────── -->
    <div id="user-section" class="user-space">

        <h2>Bienvenue, <span id="team-name-display">–</span></h2>

        <div class="upload-card">
            <h3>Déposer vos solutions</h3>
            <p>Archive <code>.zip</code> contenant les 150 fichiers de solutions (dossier <code>Solutions/Small|Medium|Large/</code>).</p>
            <input type="file" id="zip-file" accept=".zip">
            <button type="button" id="upload-btn" class="btn-upload" onclick="handleFileUpload()">
                Lancer l'évaluation
            </button>
        </div>


        <h3 style="margin-top:30px;">Votre historique</h3>
        <table id="history-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Date</th>
                    <th>Score pondéré</th>
                    <th>Instances valides</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="history-body"></tbody>
        </table>

        <button class="btn-logout" onclick="logout()">Se déconnecter</button>
    </div>

</section>

<footer>
    <p>Laboratory of Research in Computer Science and Applications (LRSIA), 2026</p>
</footer>


<script src="static/js/auth.js"></script>
</body>
</html>